<?xml version="1.0" encoding="UTF-8"?>
<CONTRACTS id="CONTRACTS-HARNES-PERCEPTION" status="DRAFT">
    <BASELINES id="CONTRACTS-BASELINES">
        <REQUIREMENTS_ANALYSIS ref="RA-HARNES-PERCEPTION" required_status="APPROVED_BY_OWNER" />
        <TECHNOLOGY ref="TECH-HARNES-PERCEPTION" required_status="APPROVED_BY_OWNER" />
        <DEVELOPMENT_PLAN ref="DP-HARNES-PERCEPTION" required_status="APPROVED_BY_OWNER" />
    </BASELINES>

    <PUBLIC_GO_API id="CONTRACT-PUBLIC-GO-API" status="APPROVED_BY_OWNER">
        <PACKAGE_NAME>perception</PACKAGE_NAME>

        <CONFIG_TYPE id="CONTRACT-TYPE-CONFIG">
            <DECLARATION>type Config struct { ArtifactDir string }</DECLARATION>
            <ARTIFACT_DIR>
                <GO_TYPE>string</GO_TYPE>
                <PURPOSE>LOCAL_ARTIFACT_BASE_DIRECTORY</PURPOSE>
            </ARTIFACT_DIR>
        </CONFIG_TYPE>

        <INSTANCE_TYPE id="CONTRACT-TYPE-INSTANCE">
            <DECLARATION>type Instance struct</DECLARATION>
            <FIELDS>UNEXPORTED</FIELDS>
            <STATE_SCOPE>PER_INSTANCE</STATE_SCOPE>
        </INSTANCE_TYPE>

        <CONSTRUCTOR id="CONTRACT-METHOD-NEW">
            <SIGNATURE>func New(config Config) (*Instance, error)</SIGNATURE>
            <BEHAVIOR>
                <CONFIGURATION_VALIDATION>BEFORE_RETURN</CONFIGURATION_VALIDATION>
                <ARTIFACT_BASE_DIRECTORY_VALIDATION>BEFORE_RETURN</ARTIFACT_BASE_DIRECTORY_VALIDATION>
                <EVENT_LOOP_START>ON_SUCCESSFUL_CONSTRUCTION</EVENT_LOOP_START>
                <SEPARATE_START_METHOD>NONE</SEPARATE_START_METHOD>
            </BEHAVIOR>
        </CONSTRUCTOR>

        <HTTP_HANDLER_METHOD id="CONTRACT-METHOD-HANDLER">
            <SIGNATURE>func (i *Instance) Handler() http.Handler</SIGNATURE>
            <INSTANCE_BINDING>SAME_RECEIVER_INSTANCE</INSTANCE_BINDING>
            <LISTENER_START>NONE</LISTENER_START>
            <GLOBAL_SERVE_MUX_REGISTRATION>NONE</GLOBAL_SERVE_MUX_REGISTRATION>
        </HTTP_HANDLER_METHOD>

        <TRY_NEXT_METHOD id="CONTRACT-METHOD-TRY-NEXT">
            <SIGNATURE>func (i *Instance) TryNext() (Observation, bool, error)</SIGNATURE>
            <CONCEPTUAL_OPERATION_NAME>Next</CONCEPTUAL_OPERATION_NAME>
            <PUBLIC_METHOD_NAME>TryNext</PUBLIC_METHOD_NAME>
            <BLOCKING>NO</BLOCKING>
            <WAIT_FOR_READY>NO</WAIT_FOR_READY>

            <RESULT id="CONTRACT-TRY-NEXT-READY">
                <CONDITION>READY_OBSERVATION_EXISTS</CONDITION>
                <OBSERVATION>FIRST_READY_IN_UNIFIED_QUEUE_ORDER</OBSERVATION>
                <FOUND>true</FOUND>
                <ERROR>nil</ERROR>
                <QUEUE_EFFECT>REMOVE_EVENT_ONLY_AFTER_SUCCESSFUL_RETURN</QUEUE_EFFECT>
            </RESULT>

            <RESULT id="CONTRACT-TRY-NEXT-NO-READY">
                <CONDITION>NO_READY_OBSERVATION</CONDITION>
                <OBSERVATION>ZERO_VALUE</OBSERVATION>
                <FOUND>false</FOUND>
                <ERROR>nil</ERROR>
                <QUEUE_EFFECT>NONE</QUEUE_EFFECT>
                <STATE_EFFECT>NONE</STATE_EFFECT>
            </RESULT>

            <RESULT id="CONTRACT-TRY-NEXT-ERROR">
                <CONDITION>INSTANCE_CLOSING_OR_CLOSED_OR_INTERNAL_COMMAND_FAILURE</CONDITION>
                <OBSERVATION>ZERO_VALUE</OBSERVATION>
                <FOUND>false</FOUND>
                <ERROR>NON_NIL</ERROR>
                <READY_EVENT_REMOVAL>NONE</READY_EVENT_REMOVAL>
            </RESULT>
        </TRY_NEXT_METHOD>

        <CLOSE_METHOD id="CONTRACT-METHOD-CLOSE">
            <SIGNATURE>func (i *Instance) Close() error</SIGNATURE>
            <BLOCKING>YES</BLOCKING>
            <RETURN_POINT>AFTER_EVENT_LOOP_AND_ACTIVE_WORKER_TERMINATION</RETURN_POINT>
            <NEW_COMMAND_ACCEPTANCE_AFTER_CLOSE_START>NONE</NEW_COMMAND_ACCEPTANCE_AFTER_CLOSE_START>
            <ACTIVE_WORKER>CANCEL</ACTIVE_WORKER>
            <IDEMPOTENT>YES</IDEMPOTENT>
            <REPEATED_SUCCESSFUL_CLOSE_RESULT>nil</REPEATED_SUCCESSFUL_CLOSE_RESULT>
        </CLOSE_METHOD>

        <DECISION_BASIS>APPROVED_BY_OWNER</DECISION_BASIS>

        <TRACES_TO>
            <DEVELOPMENT_WORK_ITEM ref="DP-WORK-CONTRACT-PUBLIC-API" />
            <TECHNOLOGY ref="TECH-IN-PROCESS-GO-API" />
            <TECHNOLOGY ref="TECH-EXPLICIT-INSTANCE-LIFECYCLE" />
            <TECHNOLOGY ref="TECH-HTTP-EVENT-INGRESS" />
            <REQUIREMENT ref="REQ-PERCEPTION-NEXT-PULL" />
            <REQUIREMENT ref="REQ-PERCEPTION-NEXT-WITHOUT-READY" />
            <REQUIREMENT ref="REQ-PERCEPTION-READY-RETENTION" />
        </TRACES_TO>
    </PUBLIC_GO_API>
</CONTRACTS>
