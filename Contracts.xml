<?xml version="1.0" encoding="UTF-8"?>
<CONTRACTS id="CONTRACTS-HARNES-PERCEPTION" status="DRAFT">
    <BASELINES id="CONTRACTS-BASELINES">
        <REQUIREMENTS_ANALYSIS ref="RA-HARNES-PERCEPTION" required_status="APPROVED_BY_OWNER" />
        <TECHNOLOGY ref="TECH-HARNES-PERCEPTION" required_status="APPROVED_BY_OWNER" />
        <DEVELOPMENT_PLAN ref="DP-HARNES-PERCEPTION" required_status="APPROVED_BY_OWNER" />
    </BASELINES>

    <PUBLIC_GO_API id="CONTRACT-PUBLIC-GO-API" status="APPROVED_BY_OWNER">
        <PACKAGE_NAME>perception</PACKAGE_NAME>

        <CONFIG_TYPE id="CONTRACT-TYPE-CONFIG">
            <DECLARATION>type Config struct { ArtifactDir string }</DECLARATION>
            <ARTIFACT_DIR>
                <GO_TYPE>string</GO_TYPE>
                <PURPOSE>LOCAL_ARTIFACT_BASE_DIRECTORY</PURPOSE>
            </ARTIFACT_DIR>
        </CONFIG_TYPE>

        <INSTANCE_TYPE id="CONTRACT-TYPE-INSTANCE">
            <DECLARATION>type Instance struct</DECLARATION>
            <FIELDS>UNEXPORTED</FIELDS>
            <STATE_SCOPE>PER_INSTANCE</STATE_SCOPE>
        </INSTANCE_TYPE>

        <CONSTRUCTOR id="CONTRACT-METHOD-NEW">
            <SIGNATURE>func New(config Config) (*Instance, error)</SIGNATURE>
            <BEHAVIOR>
                <CONFIGURATION_VALIDATION>BEFORE_RETURN</CONFIGURATION_VALIDATION>
                <ARTIFACT_BASE_DIRECTORY_VALIDATION>BEFORE_RETURN</ARTIFACT_BASE_DIRECTORY_VALIDATION>
                <EVENT_LOOP_START>ON_SUCCESSFUL_CONSTRUCTION</EVENT_LOOP_START>
                <SEPARATE_START_METHOD>NONE</SEPARATE_START_METHOD>
            </BEHAVIOR>
        </CONSTRUCTOR>

        <HTTP_HANDLER_METHOD id="CONTRACT-METHOD-HANDLER">
            <SIGNATURE>func (i *Instance) Handler() http.Handler</SIGNATURE>
            <INSTANCE_BINDING>SAME_RECEIVER_INSTANCE</INSTANCE_BINDING>
            <LISTENER_START>NONE</LISTENER_START>
            <GLOBAL_SERVE_MUX_REGISTRATION>NONE</GLOBAL_SERVE_MUX_REGISTRATION>
        </HTTP_HANDLER_METHOD>

        <TRY_NEXT_METHOD id="CONTRACT-METHOD-TRY-NEXT">
            <SIGNATURE>func (i *Instance) TryNext() (Observation, bool, error)</SIGNATURE>
            <CONCEPTUAL_OPERATION_NAME>Next</CONCEPTUAL_OPERATION_NAME>
            <PUBLIC_METHOD_NAME>TryNext</PUBLIC_METHOD_NAME>
            <BLOCKING>NO</BLOCKING>
            <WAIT_FOR_READY>NO</WAIT_FOR_READY>

            <RESULT id="CONTRACT-TRY-NEXT-READY">
                <CONDITION>READY_OBSERVATION_EXISTS</CONDITION>
                <OBSERVATION>FIRST_READY_IN_UNIFIED_QUEUE_ORDER</OBSERVATION>
                <FOUND>true</FOUND>
                <ERROR>nil</ERROR>
                <QUEUE_EFFECT>REMOVE_EVENT_ONLY_AFTER_SUCCESSFUL_RETURN</QUEUE_EFFECT>
            </RESULT>

            <RESULT id="CONTRACT-TRY-NEXT-NO-READY">
                <CONDITION>NO_READY_OBSERVATION</CONDITION>
                <OBSERVATION>ZERO_VALUE</OBSERVATION>
                <FOUND>false</FOUND>
                <ERROR>nil</ERROR>
                <QUEUE_EFFECT>NONE</QUEUE_EFFECT>
                <STATE_EFFECT>NONE</STATE_EFFECT>
            </RESULT>

            <RESULT id="CONTRACT-TRY-NEXT-ERROR">
                <CONDITION>INSTANCE_CLOSING_OR_CLOSED_OR_INTERNAL_COMMAND_FAILURE</CONDITION>
                <OBSERVATION>ZERO_VALUE</OBSERVATION>
                <FOUND>false</FOUND>
                <ERROR>NON_NIL</ERROR>
                <READY_EVENT_REMOVAL>NONE</READY_EVENT_REMOVAL>
            </RESULT>
        </TRY_NEXT_METHOD>

        <CLOSE_METHOD id="CONTRACT-METHOD-CLOSE">
            <SIGNATURE>func (i *Instance) Close() error</SIGNATURE>
            <BLOCKING>YES</BLOCKING>
            <RETURN_POINT>AFTER_EVENT_LOOP_AND_ACTIVE_WORKER_TERMINATION</RETURN_POINT>
            <NEW_COMMAND_ACCEPTANCE_AFTER_CLOSE_START>NONE</NEW_COMMAND_ACCEPTANCE_AFTER_CLOSE_START>
            <ACTIVE_WORKER>CANCEL</ACTIVE_WORKER>
            <IDEMPOTENT>YES</IDEMPOTENT>
            <REPEATED_SUCCESSFUL_CLOSE_RESULT>nil</REPEATED_SUCCESSFUL_CLOSE_RESULT>
        </CLOSE_METHOD>

        <DECISION_BASIS>APPROVED_BY_OWNER</DECISION_BASIS>

        <TRACES_TO>
            <DEVELOPMENT_WORK_ITEM ref="DP-WORK-CONTRACT-PUBLIC-API" />
            <TECHNOLOGY ref="TECH-IN-PROCESS-GO-API" />
            <TECHNOLOGY ref="TECH-EXPLICIT-INSTANCE-LIFECYCLE" />
            <TECHNOLOGY ref="TECH-HTTP-EVENT-INGRESS" />
            <REQUIREMENT ref="REQ-PERCEPTION-NEXT-PULL" />
            <REQUIREMENT ref="REQ-PERCEPTION-NEXT-WITHOUT-READY" />
            <REQUIREMENT ref="REQ-PERCEPTION-READY-RETENTION" />
        </TRACES_TO>
    </PUBLIC_GO_API>

    <PUBLIC_DATA_TYPES id="CONTRACT-PUBLIC-DATA-TYPES" status="APPROVED_BY_OWNER">
        <IMPORTANCE_TYPE id="CONTRACT-TYPE-IMPORTANCE">
            <DECLARATION>type Importance string</DECLARATION>
            <CONSTANTS>
                <CONSTANT name="ImportanceLow" value="low" />
                <CONSTANT name="ImportanceMedium" value="medium" />
                <CONSTANT name="ImportanceHigh" value="high" />
            </CONSTANTS>
            <VALID_VALUES>low medium high</VALID_VALUES>
            <PASSTHROUGH>UNCHANGED_FROM_ACCEPTED_EVENT</PASSTHROUGH>
        </IMPORTANCE_TYPE>

        <ARTIFACT_REF_TYPE id="CONTRACT-TYPE-ARTIFACT-REF">
            <DECLARATION>type ArtifactRef string</DECLARATION>
            <SEMANTICS>CLEANED_RELATIVE_PATH_WITHIN_CONFIG_ARTIFACT_DIR</SEMANTICS>
            <TARGET>EXISTING_REGULAR_FILE</TARGET>
            <SYMLINKS>PROHIBITED</SYMLINKS>
            <FILE_COPYING>NONE</FILE_COPYING>
        </ARTIFACT_REF_TYPE>

        <OBSERVATION_TYPE id="CONTRACT-TYPE-OBSERVATION">
            <DECLARATION>type Observation struct { SourceID string; Importance Importance; ReceivedAt time.Time; Data any; Artifacts []ArtifactRef }</DECLARATION>
            <JSON_TAGS>NONE</JSON_TAGS>

            <FIELD name="SourceID">
                <GO_TYPE>string</GO_TYPE>
                <SEMANTICS>EXTERNAL_SOURCE_ID</SEMANTICS>
            </FIELD>
            <FIELD name="Importance">
                <GO_TYPE>Importance</GO_TYPE>
                <SEMANTICS>UNCHANGED_ACCEPTED_IMPORTANCE</SEMANTICS>
            </FIELD>
            <FIELD name="ReceivedAt">
                <GO_TYPE>time.Time</GO_TYPE>
                <SEMANTICS>INITIAL_EVENT_ACCEPTANCE_TIME</SEMANTICS>
                <REPROCESSING>PRESERVE_ORIGINAL_VALUE</REPROCESSING>
            </FIELD>
            <FIELD name="Data">
                <GO_TYPE>any</GO_TYPE>
                <ALLOWED_TREE>nil bool string json.Number []any map[string]any</ALLOWED_TREE>
                <SEMANTIC_ENRICHMENT>NONE</SEMANTIC_ENRICHMENT>
            </FIELD>
            <FIELD name="Artifacts">
                <GO_TYPE>[]ArtifactRef</GO_TYPE>
                <NO_ARTIFACTS>NIL_OR_EMPTY_SLICE</NO_ARTIFACTS>
            </FIELD>
        </OBSERVATION_TYPE>

        <DECISION_BASIS>APPROVED_BY_OWNER</DECISION_BASIS>

        <TRACES_TO>
            <DEVELOPMENT_WORK_ITEM ref="DP-WORK-CONTRACT-DATA" />
            <TECHNOLOGY ref="TECH-TYPED-GO-CANONICAL-OBSERVATION" />
            <TECHNOLOGY ref="TECH-UNIVERSAL-GO-JSON-VALUE-TREE" />
            <TECHNOLOGY ref="TECH-PROCESS-SYSTEM-CLOCK" />
            <TECHNOLOGY ref="TECH-LOCAL-FILE-ARTIFACTS" />
            <REQUIREMENT ref="REQ-PERCEPTION-SOURCE-ID" />
            <REQUIREMENT ref="REQ-PERCEPTION-RECEIPT-TIMESTAMP" />
            <REQUIREMENT ref="REQ-PERCEPTION-ARTIFACT-LINK" />
            <REQUIREMENT ref="REQ-PERCEPTION-IMPORTANCE-LEVELS" />
            <REQUIREMENT ref="REQ-PERCEPTION-IMPORTANCE-PASSTHROUGH" />
            <INVARIANT ref="INV-PERCEPTION-IMPORTANCE-UNCHANGED" />
            <INVARIANT ref="INV-PERCEPTION-ARRIVAL-TIME-UNCHANGED" />
        </TRACES_TO>
    </PUBLIC_DATA_TYPES>
    <HTTP_INGRESS_CONTRACT id="CONTRACT-HTTP-INGRESS" status="DRAFT">
        <APPROVED_REQUEST_AND_RESPONSE
            id="CONTRACT-HTTP-REQUEST-RESPONSE"
            status="APPROVED_BY_OWNER">
            <REQUEST id="CONTRACT-HTTP-REQUEST">
                <METHOD>POST</METHOD>
                <CONTENT_TYPE>application/json</CONTENT_TYPE>
                <CONTENT_TYPE_PARAMETERS>ALLOWED</CONTENT_TYPE_PARAMETERS>
                <BODY_ROOT>JSON_OBJECT</BODY_ROOT>
                <TRAILING_JSON_VALUES>REJECT</TRAILING_JSON_VALUES>
                <DECODER>encoding/json.Decoder</DECODER>
                <DECODER_USE_NUMBER>YES</DECODER_USE_NUMBER>

                <FIELD name="source_id" required="YES">
                    <JSON_TYPE>string</JSON_TYPE>
                    <EMPTY_STRING>REJECT</EMPTY_STRING>
                </FIELD>

                <FIELD name="importance" required="YES">
                    <JSON_TYPE>string</JSON_TYPE>
                    <VALID_VALUES>low medium high</VALID_VALUES>
                </FIELD>

                <FIELD name="data" required="YES">
                    <JSON_TYPE>ANY_JSON_VALUE</JSON_TYPE>
                    <NULL>ALLOWED</NULL>
                    <NUMBER_REPRESENTATION>json.Number</NUMBER_REPRESENTATION>
                </FIELD>

                <FIELD name="artifact" required="NO">
                    <ABSENT>NO_ARTIFACTS</ABSENT>
                    <ALLOWED_JSON_FORMS>
                        <FORM>NON_EMPTY_RELATIVE_PATH_STRING</FORM>
                        <FORM>NON_EMPTY_ARRAY_OF_NON_EMPTY_RELATIVE_PATH_STRINGS</FORM>
                    </ALLOWED_JSON_FORMS>
                    <EMPTY_STRING>REJECT</EMPTY_STRING>
                    <EMPTY_ARRAY>REJECT</EMPTY_ARRAY>
                    <EMPTY_ARRAY_ELEMENT>REJECT</EMPTY_ARRAY_ELEMENT>
                </FIELD>
            </REQUEST>

            <ARTIFACT_ACCEPTANCE_VALIDATION id="CONTRACT-HTTP-ARTIFACT-VALIDATION">
                <TIMING>BEFORE_EVENT_ACCEPTANCE_AND_HTTP_202_RESPONSE</TIMING>
                <PATH_FORM>RELATIVE_ONLY</PATH_FORM>
                <NORMALIZATION>filepath.Clean</NORMALIZATION>
                <ABSOLUTE_PATH>REJECT</ABSOLUTE_PATH>
                <PARENT_TRAVERSAL>REJECT</PARENT_TRAVERSAL>
                <BASE_AND_COMPONENT_INSPECTION>os.Lstat</BASE_AND_COMPONENT_INSPECTION>
                <BASE_SYMLINK>REJECT</BASE_SYMLINK>
                <COMPONENT_SYMLINK>REJECT</COMPONENT_SYMLINK>
                <INTERMEDIATE_COMPONENT>EXISTING_DIRECTORY</INTERMEDIATE_COMPONENT>
                <TARGET>EXISTING_REGULAR_FILE</TARGET>
                <STORED_REFERENCE>
                    ArtifactRef_WITH_CLEANED_RELATIVE_PATH
                </STORED_REFERENCE>
                <FILE_COPYING>NONE</FILE_COPYING>
                <ACCEPTANCE_GUARANTEE>
                    EVENT_AND_ARTIFACT_REFERENCES_VALID_AT_ACCEPTANCE_TIME
                </ACCEPTANCE_GUARANTEE>
                <POST_ACCEPTANCE_FILE_CHANGE>
                    MAY_CAUSE_LATER_NORMALIZATION_FAILURE
                </POST_ACCEPTANCE_FILE_CHANGE>
            </ARTIFACT_ACCEPTANCE_VALIDATION>

            <ACCEPTANCE id="CONTRACT-HTTP-ACCEPTANCE">
                <VALIDATION_COMPLETION>BEFORE_ACCEPTANCE_DECISION</VALIDATION_COMPLETION>
                <DECISION_OWNER>CONTROL_EVENT_LOOP</DECISION_OWNER>
                <RECEIVED_AT_CAPTURE>
                    AT_INITIAL_EVENT_ACCEPTANCE
                </RECEIVED_AT_CAPTURE>
                <ACCEPTANCE_SEQUENCE_ASSIGNMENT>
                    AT_INITIAL_EVENT_ACCEPTANCE
                </ACCEPTANCE_SEQUENCE_ASSIGNMENT>
                <QUEUE_INSERTION>BEFORE_HTTP_RESPONSE</QUEUE_INSERTION>
                <NORMALIZATION_WAIT>NONE</NORMALIZATION_WAIT>
                <READY_WAIT>NONE</READY_WAIT>
                <REJECTION_QUEUE_EFFECT>NONE</REJECTION_QUEUE_EFFECT>
            </ACCEPTANCE>

            <RESPONSE_MEDIA_TYPE>application/json</RESPONSE_MEDIA_TYPE>

            <RESPONSE id="CONTRACT-HTTP-RESPONSE-ACCEPTED">
                <CONDITION>
                    EVENT_ACCEPTED_AND_INSERTED_IN_UNIFIED_QUEUE
                </CONDITION>
                <STATUS>202</STATUS>
                <STATUS_TEXT>Accepted</STATUS_TEXT>
                <BODY>{"accepted":true}</BODY>
            </RESPONSE>

            <RESPONSE id="CONTRACT-HTTP-RESPONSE-BAD-REQUEST">
                <CONDITION>
                    INVALID_JSON_OR_REQUEST_FIELD_OR_ARTIFACT
                </CONDITION>
                <STATUS>400</STATUS>
                <STATUS_TEXT>Bad Request</STATUS_TEXT>
                <BODY_SHAPE>
                    {"error":{"code":"string","message":"string"}}
                </BODY_SHAPE>
            </RESPONSE>

            <RESPONSE id="CONTRACT-HTTP-RESPONSE-METHOD-NOT-ALLOWED">
                <CONDITION>METHOD_IS_NOT_POST</CONDITION>
                <STATUS>405</STATUS>
                <STATUS_TEXT>Method Not Allowed</STATUS_TEXT>
                <HEADER name="Allow">POST</HEADER>
                <BODY_SHAPE>
                    {"error":{"code":"method_not_allowed","message":"string"}}
                </BODY_SHAPE>
            </RESPONSE>

            <RESPONSE id="CONTRACT-HTTP-RESPONSE-UNSUPPORTED-MEDIA-TYPE">
                <CONDITION>
                    MEDIA_TYPE_IS_NOT_APPLICATION_JSON
                </CONDITION>
                <STATUS>415</STATUS>
                <STATUS_TEXT>Unsupported Media Type</STATUS_TEXT>
                <BODY_SHAPE>
                    {"error":{"code":"unsupported_media_type","message":"string"}}
                </BODY_SHAPE>
            </RESPONSE>

            <RESPONSE id="CONTRACT-HTTP-RESPONSE-INSTANCE-UNAVAILABLE">
                <CONDITION>INSTANCE_CLOSING_OR_CLOSED</CONDITION>
                <STATUS>503</STATUS>
                <STATUS_TEXT>Service Unavailable</STATUS_TEXT>
                <BODY_SHAPE>
                    {"error":{"code":"instance_unavailable","message":"string"}}
                </BODY_SHAPE>
            </RESPONSE>

            <RESPONSE id="CONTRACT-HTTP-RESPONSE-INTERNAL-ERROR">
                <CONDITION>
                    INTERNAL_EVENT_LOOP_COMMAND_FAILURE
                </CONDITION>
                <STATUS>500</STATUS>
                <STATUS_TEXT>Internal Server Error</STATUS_TEXT>
                <BODY_SHAPE>
                    {"error":{"code":"internal_error","message":"string"}}
                </BODY_SHAPE>
            </RESPONSE>

            <ERROR_CODES id="CONTRACT-HTTP-ERROR-CODES">
                <ERROR_CODE
                    value="method_not_allowed"
                    status="405" />
                <ERROR_CODE
                    value="unsupported_media_type"
                    status="415" />
                <ERROR_CODE
                    value="invalid_json"
                    status="400" />
                <ERROR_CODE
                    value="missing_source_id"
                    status="400" />
                <ERROR_CODE
                    value="invalid_source_id"
                    status="400" />
                <ERROR_CODE
                    value="missing_importance"
                    status="400" />
                <ERROR_CODE
                    value="invalid_importance"
                    status="400" />
                <ERROR_CODE
                    value="missing_data"
                    status="400" />
                <ERROR_CODE
                    value="invalid_artifact"
                    status="400" />
                <ERROR_CODE
                    value="instance_unavailable"
                    status="503" />
                <ERROR_CODE
                    value="internal_error"
                    status="500" />
            </ERROR_CODES>

            <DECISION_BASIS>APPROVED_BY_OWNER</DECISION_BASIS>

            <TRACES_TO>
                <DEVELOPMENT_WORK_ITEM ref="DP-WORK-CONTRACT-HTTP" />
                <TECHNOLOGY ref="TECH-HTTP-EVENT-INGRESS" />
                <TECHNOLOGY ref="TECH-UNIVERSAL-GO-JSON-VALUE-TREE" />
                <TECHNOLOGY ref="TECH-LOCAL-FILE-ARTIFACTS" />
                <TECHNOLOGY ref="TECH-CONTROL-EVENT-LOOP" />
                <REQUIREMENT ref="REQ-PERCEPTION-SOURCE-ID" />
                <REQUIREMENT ref="REQ-PERCEPTION-RECEIPT-TIMESTAMP" />
                <REQUIREMENT ref="REQ-PERCEPTION-PREPROCESSING-EXTRACTION" />
                <REQUIREMENT ref="REQ-PERCEPTION-ARTIFACT-LINK" />
                <REQUIREMENT ref="REQ-PERCEPTION-IMPORTANCE-LEVELS" />
                <ERROR_CASE ref="ERR-PERCEPTION-MISSING-IMPORTANCE" />
                <ERROR_CASE ref="ERR-PERCEPTION-INVALID-IMPORTANCE" />
            </TRACES_TO>
        </APPROVED_REQUEST_AND_RESPONSE>

        <OPEN_DECISIONS>
            <DECISION id="CONTRACT-HTTP-OPEN-UNKNOWN-FIELDS">
                UNKNOWN_JSON_FIELD_POLICY
            </DECISION>
        </OPEN_DECISIONS>
    </HTTP_INGRESS_CONTRACT>
</CONTRACTS>
