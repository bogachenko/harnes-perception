        </EVENT_QUEUE>

        <CONCURRENCY_MODEL id="TECH-CONTROL-EVENT-LOOP">
            <MODEL>SINGLE_OWNER_EVENT_LOOP</MODEL>
            <OWNER>ONE_GOROUTINE_PER_INSTANCE</OWNER>
            <OWNED_STATE>UNIFIED_QUEUE_AND_EVENT_STATES</OWNED_STATE>
            <STATE_ACCESS>EVENT_LOOP_ONLY</STATE_ACCESS>
            <INGRESS_COMMAND_TRANSPORT>GO_CHANNEL</INGRESS_COMMAND_TRANSPORT>
            <INGRESS_DECISION_TRANSPORT>GO_CHANNEL</INGRESS_DECISION_TRANSPORT>
            <INGRESS_COMPLETION>AFTER_EVENT_LOOP_ACCEPT_OR_REJECT</INGRESS_COMPLETION>
            <NEXT_COMMAND_TRANSPORT>GO_CHANNEL</NEXT_COMMAND_TRANSPORT>
            <WORKER_RESULT_TRANSPORT>GO_CHANNEL</WORKER_RESULT_TRANSPORT>
            <NORMALIZATION_EXECUTION>SEPARATE_WORKER_GOROUTINE</NORMALIZATION_EXECUTION>
            <ACTIVE_NORMALIZATION_WORKERS>AT_MOST_ONE_PER_INSTANCE</ACTIVE_NORMALIZATION_WORKERS>
            <EVENT_LOOP_BLOCKED_BY_NORMALIZATION>NO</EVENT_LOOP_BLOCKED_BY_NORMALIZATION>
            <PREEMPTION_CONTROL ref="TECH-CONTEXT-CANCELLATION" />
            <DIRECT_QUEUE_ACCESS_OUTSIDE_EVENT_LOOP>NONE</DIRECT_QUEUE_ACCESS_OUTSIDE_EVENT_LOOP>
            <DECISION_BASIS>APPROVED_BY_OWNER</DECISION_BASIS>
            <RATIONALE>
                Одна управляющая goroutine экземпляра эксклюзивно владеет единой
                очередью и состояниями событий. HTTP-вход, вызовы Next() и результаты
                worker передаются ей командами через Go channels. Нормализация
                выполняется отдельной worker goroutine, поэтому event loop продолжает
                принимать новые события и при поступлении более важного события
                отменяет текущую нормализацию через context.Context.
                Решение о принятии или отклонении входного события возвращается HTTP-входу
                через Go channel до завершения запроса; нормализация для ответа не ожидается.
            </RATIONALE>
            <TRACES_TO>
                <REQUIREMENT ref="REQ-PERCEPTION-IMPORTANCE-PREEMPTION" />
                <REQUIREMENT ref="REQ-PERCEPTION-ATOMIC-PROCESSING" />
                <REQUIREMENT ref="REQ-PERCEPTION-SINGLE-QUEUE" />
                <REQUIREMENT ref="REQ-PERCEPTION-NEXT-PULL" />
                <REQUIREMENT ref="REQ-PERCEPTION-NEXT-WITHOUT-READY" />
                <INVARIANT ref="INV-PERCEPTION-NO-PARTIAL-OBSERVATION" />
            </TRACES_TO>
        </CONCURRENCY_MODEL>

        <INSTANCE_LIFECYCLE id="TECH-EXPLICIT-INSTANCE-LIFECYCLE">
            <START_TRIGGER>SUCCESSFUL_INSTANCE_CONSTRUCTION</START_TRIGGER>
            <EVENT_LOOP_START>AUTOMATIC_ON_SUCCESSFUL_CONSTRUCTION</EVENT_LOOP_START>
            <SEPARATE_START_OPERATION>NONE</SEPARATE_START_OPERATION>
            <SHUTDOWN_TRIGGER>EXPLICIT_INSTANCE_CLOSE</SHUTDOWN_TRIGGER>
            <NEW_COMMAND_ACCEPTANCE_AFTER_CLOSE>NONE</NEW_COMMAND_ACCEPTANCE_AFTER_CLOSE>
            <ACTIVE_WORKER_ON_CLOSE>CANCEL_VIA_CONTEXT</ACTIVE_WORKER_ON_CLOSE>
            <EVENT_LOOP_ON_CLOSE>STOP</EVENT_LOOP_ON_CLOSE>
            <CLOSE_COMPLETION>AFTER_EVENT_LOOP_AND_WORKER_TERMINATION</CLOSE_COMPLETION>
            <REPEATED_CLOSE>SAFE</REPEATED_CLOSE>
            <DECISION_BASIS>APPROVED_BY_OWNER</DECISION_BASIS>
            <RATIONALE>
                Управляющий event loop запускается при успешном создании экземпляра;
                отдельная операция запуска не требуется. Явное закрытие экземпляра
                прекращает приём новых команд, отменяет активную worker через context.Context
                и завершается после остановки event loop и worker. Повторное закрытие безопасно.
            </RATIONALE>
            <TRACES_TO>
                <REQUIREMENT ref="REQ-PERCEPTION-IMPORTANCE-PREEMPTION" />
                <REQUIREMENT ref="REQ-PERCEPTION-ATOMIC-PROCESSING" />
                <REQUIREMENT ref="REQ-PERCEPTION-ORCHESTRATOR-INDEPENDENCE" />
            </TRACES_TO>
        </INSTANCE_LIFECYCLE>

        <CANCELLATION_CONTROL id="TECH-CONTEXT-CANCELLATION">
