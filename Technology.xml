                <REQUIREMENT ref="REQ-PERCEPTION-PREPROCESSING-EXTRACTION" />
                <REQUIREMENT ref="REQ-PERCEPTION-ARTIFACT-LINK" />
            </TRACES_TO>
        </INPUT_EVENT>

