<?xml version="1.0" encoding="UTF-8"?>
<TECHNOLOGY id="TECH-HARNES-PERCEPTION" status="DRAFT">
    <LANGUAGE id="TECH-LANGUAGE-GO">
        <NAME>Go</NAME>
        <GO_DIRECTIVE>1.25.4</GO_DIRECTIVE>
        <DECISION_BASIS>APPROVED_BY_OWNER</DECISION_BASIS>
        <RATIONALE>
            Фиксирует утверждённые владельцем язык реализации
            и значение директивы go.
        </RATIONALE>
        <TRACES_TO>
            <GOAL ref="GOAL-PERCEPTION-001" />
            <BUSINESS_PROCESS ref="BP-PERCEPTION-EVENT-PROCESSING" />
        </TRACES_TO>
    </LANGUAGE>

    <FRAMEWORKS id="TECH-FRAMEWORKS">
        <APPLICATION_FRAMEWORK id="TECH-APPLICATION-FRAMEWORK">
            <SELECTION>NONE</SELECTION>
            <DECISION_BASIS>APPROVED_BY_OWNER</DECISION_BASIS>
            <RATIONALE>
                Реализация harnes-perception выполняется без прикладного
                Go-фреймворка.
            </RATIONALE>
            <TRACES_TO>
                <GOAL ref="GOAL-PERCEPTION-001" />
                <BUSINESS_PROCESS ref="BP-PERCEPTION-EVENT-PROCESSING" />
            </TRACES_TO>
        </APPLICATION_FRAMEWORK>
    </FRAMEWORKS>

    <LIBRARIES id="TECH-LIBRARIES">
        <STANDARD_LIBRARY id="TECH-GO-STANDARD-LIBRARY">
            <SELECTION>GO_STANDARD_LIBRARY_ONLY</SELECTION>
            <THIRD_PARTY_LIBRARIES>NONE</THIRD_PARTY_LIBRARIES>
            <COMPATIBILITY ref="TECH-LANGUAGE-GO" />
            <DECISION_BASIS>APPROVED_BY_OWNER</DECISION_BASIS>
            <RATIONALE>
                Реализация использует только стандартную библиотеку Go
                без сторонних библиотек.
            </RATIONALE>
            <TRACES_TO>
                <GOAL ref="GOAL-PERCEPTION-001" />
                <BUSINESS_PROCESS ref="BP-PERCEPTION-EVENT-PROCESSING" />
            </TRACES_TO>
        </STANDARD_LIBRARY>
    </LIBRARIES>

    <DATA_REPRESENTATION id="TECH-DATA-REPRESENTATION">
        <INPUT_EVENT id="TECH-TYPED-GO-INPUT-EVENT">
            <TRANSPORT_SOURCE>HTTP_REQUEST</TRANSPORT_SOURCE>
            <DECODING_LOCATION>HARNES_PERCEPTION_HTTP_SERVER</DECODING_LOCATION>
            <REPRESENTATION>TYPED_GO_VALUE_AFTER_HTTP_DECODING</REPRESENTATION>
            <DECISION_BASIS>APPROVED_BY_OWNER</DECISION_BASIS>
            <RATIONALE>
                HTTP-сервер harnes-perception принимает внешнее событие,
                декодирует его транспортное представление внутри сервиса
                и передаёт на обработку типизированное значение Go.
            </RATIONALE>
            <TRACES_TO>
                <INPUT ref="INPUT-EXTERNAL-EVENT" />
                <ENTITY ref="ENTITY-PERCEPTION-INPUT-EVENT" />
                <REQUIREMENT ref="REQ-PERCEPTION-PREPROCESSING-EXTRACTION" />
            </TRACES_TO>
        </INPUT_EVENT>

        <CANONICAL_OBSERVATION id="TECH-TYPED-GO-CANONICAL-OBSERVATION">
            <REPRESENTATION>TYPED_GO_STRUCT</REPRESENTATION>
            <DECISION_BASIS>APPROVED_BY_OWNER</DECISION_BASIS>
            <RATIONALE>
                Внутри сервиса harnes-perception формирует каноническое наблюдение
                как типизированную Go-структуру.
            </RATIONALE>
            <TRACES_TO>
                <OUTPUT ref="OUTPUT-CANONICAL-OBSERVATION" />
                <ENTITY ref="ENTITY-PERCEPTION-CANONICAL-OBSERVATION" />
            </TRACES_TO>
        </CANONICAL_OBSERVATION>
    </DATA_REPRESENTATION>

    <RUNTIME_ENVIRONMENT id="TECH-RUNTIME-ENVIRONMENT">
        <OPERATING_SYSTEM>Linux</OPERATING_SYSTEM>
        <KERNEL>Linux</KERNEL>
        <ARCHITECTURE>x86-64</ARCHITECTURE>
        <DECISION_BASIS>APPROVED_BY_OWNER</DECISION_BASIS>
        <RATIONALE>
            Среда исполнения ограничена утверждённой владельцем платформой
            Linux на архитектуре x86-64.
        </RATIONALE>
        <TRACES_TO>
            <GOAL ref="GOAL-PERCEPTION-001" />
            <BUSINESS_PROCESS ref="BP-PERCEPTION-EVENT-PROCESSING" />
        </TRACES_TO>
    </RUNTIME_ENVIRONMENT>

    <INFRASTRUCTURE id="TECH-INFRASTRUCTURE">
        <EVENT_QUEUE id="TECH-IN-PROCESS-EVENT-QUEUE">
            <LOCATION>GO_PROCESS</LOCATION>
            <EXTERNAL_BROKER>NONE</EXTERNAL_BROKER>
            <DATABASE>NONE</DATABASE>
            <DECISION_BASIS>APPROVED_BY_OWNER</DECISION_BASIS>
            <RATIONALE>
                Очередь входных событий размещается внутри процесса Go
                без внешнего брокера и базы данных.
            </RATIONALE>
            <TRACES_TO>
                <REQUIREMENT ref="REQ-PERCEPTION-IMPORTANCE-ORDER" />
                <REQUIREMENT ref="REQ-PERCEPTION-EQUAL-IMPORTANCE-ORDER" />
                <REQUIREMENT ref="REQ-PERCEPTION-IMPORTANCE-PREEMPTION" />
                <REQUIREMENT ref="REQ-PERCEPTION-QUEUE-RETENTION" />
                <REQUIREMENT ref="REQ-PERCEPTION-RESTART-AFTER-PREEMPTION" />
            </TRACES_TO>
        </EVENT_QUEUE>

        <CANCELLATION_CONTROL id="TECH-CONTEXT-CANCELLATION">
            <MECHANISM>context.Context</MECHANISM>
            <CANCELLATION>SUPPORTED</CANCELLATION>
            <LIBRARY>GO_STANDARD_LIBRARY_CONTEXT</LIBRARY>
            <PROCESS_BOUNDARY>IN_PROCESS</PROCESS_BOUNDARY>
            <DECISION_BASIS>APPROVED_BY_OWNER</DECISION_BASIS>
            <RATIONALE>
                Полная отмена текущей обработки выполняется стандартным
                механизмом context.Context с отменой.
            </RATIONALE>
            <TRACES_TO>
                <REQUIREMENT ref="REQ-PERCEPTION-IMPORTANCE-PREEMPTION" />
                <REQUIREMENT ref="REQ-PERCEPTION-ATOMIC-PROCESSING" />
                <REQUIREMENT ref="REQ-PERCEPTION-RESTART-AFTER-PREEMPTION" />
            </TRACES_TO>
        </CANCELLATION_CONTROL>

        <TIME_SOURCE id="TECH-PROCESS-SYSTEM-CLOCK">
            <CLOCK_SOURCE>PROCESS_SYSTEM_CLOCK</CLOCK_SOURCE>
            <LIBRARY>GO_STANDARD_LIBRARY_TIME</LIBRARY>
            <CAPTURE_POINT>INITIAL_EVENT_ACCEPTANCE</CAPTURE_POINT>
            <REPROCESSING_BEHAVIOR>PRESERVE_ORIGINAL_VALUE</REPROCESSING_BEHAVIOR>
            <DECISION_BASIS>APPROVED_BY_OWNER</DECISION_BASIS>
            <RATIONALE>
                Момент первоначального поступления события фиксируется
                по системным часам процесса через стандартный пакет Go time.
                При отмене и повторной обработке значение не изменяется.
            </RATIONALE>
            <TRACES_TO>
                <REQUIREMENT ref="REQ-PERCEPTION-RECEIPT-TIMESTAMP" />
                <INVARIANT ref="INV-PERCEPTION-ARRIVAL-TIME-UNCHANGED" />
                <OUTPUT ref="OUTPUT-CANONICAL-OBSERVATION" />
            </TRACES_TO>
        </TIME_SOURCE>

        <FILE_ARTIFACTS id="TECH-LOCAL-FILE-ARTIFACTS">
            <STORAGE_LOCATION>LOCAL_DIRECTORY</STORAGE_LOCATION>
            <DIRECTORY_PATH_SOURCE>PROVIDED_AT_INITIALIZATION</DIRECTORY_PATH_SOURCE>
            <REFERENCE_TARGET>EXISTING_LOCAL_FILE</REFERENCE_TARGET>
            <REFERENCE_REPRESENTATION>RELATIVE_PATH</REFERENCE_REPRESENTATION>
            <REFERENCE_BASE>INITIALIZATION_DIRECTORY</REFERENCE_BASE>
            <FILE_COPYING>NONE</FILE_COPYING>
            <DECISION_BASIS>APPROVED_BY_OWNER</DECISION_BASIS>
            <RATIONALE>
                Файловые артефакты находятся в локальной папке, путь к которой
                задаётся при инициализации. Для каждого переданного артефакта
                harnes-perception создаёт ссылку в виде относительного пути
                внутри этой папки на существующий локальный файл без его копирования.
            </RATIONALE>
            <TRACES_TO>
                <INPUT ref="INPUT-EXTERNAL-EVENT" />
                <OUTPUT ref="OUTPUT-CANONICAL-OBSERVATION" />
                <REQUIREMENT ref="REQ-PERCEPTION-ARTIFACT-LINK" />
                <CRITERION ref="CRITERION-PERCEPTION-SUCCESS" />
            </TRACES_TO>
        </FILE_ARTIFACTS>
    </INFRASTRUCTURE>

    <SECURITY id="TECH-SECURITY">
        <AUTHENTICATION>NONE</AUTHENTICATION>
        <AUTHORIZATION>NONE</AUTHORIZATION>
        <PROCESS_ACCESS_CONTROL>RUNTIME_ENVIRONMENT</PROCESS_ACCESS_CONTROL>
        <LOCAL_DIRECTORY_ACCESS_CONTROL>LINUX_FILE_PERMISSIONS</LOCAL_DIRECTORY_ACCESS_CONTROL>
        <DECISION_BASIS>APPROVED_BY_OWNER</DECISION_BASIS>
        <RATIONALE>
            harnes-perception не реализует собственную аутентификацию
            и авторизацию. Доступ к процессу и локальной папке
            контролируется окружением и файловыми правами Linux.
        </RATIONALE>
        <TRACES_TO>
            <ACTOR ref="ACTOR-EXTERNAL-SOURCE" />
            <ACTOR ref="ACTOR-GOOGLE-ADK-GO-ORCHESTRATOR" />
            <USE_CASE ref="UC-PERCEPTION-SUBMIT-EXTERNAL-DATA" />
            <USE_CASE ref="UC-PERCEPTION-RETURN-CANONICAL-OBSERVATION" />
        </TRACES_TO>
    </SECURITY>

    <INTEGRATION_INTERFACE id="TECH-HTTP-SERVER-API">
        <MECHANISM>HTTP_SERVER</MECHANISM>
        <PROCESS_BOUNDARY>INTER_PROCESS_OVER_NETWORK</PROCESS_BOUNDARY>
        <INTERNAL_INPUT_REPRESENTATION ref="TECH-TYPED-GO-INPUT-EVENT" />
        <INTERNAL_OUTPUT_REPRESENTATION ref="TECH-TYPED-GO-CANONICAL-OBSERVATION" />
        <DIRECT_GOOGLE_ADK_DEPENDENCY>NONE</DIRECT_GOOGLE_ADK_DEPENDENCY>
        <ORCHESTRATOR_BOUNDARY>EXTERNAL_TO_HARNES_PERCEPTION</ORCHESTRATOR_BOUNDARY>
        <DECISION_BASIS>APPROVED_BY_OWNER</DECISION_BASIS>
        <RATIONALE>
            harnes-perception работает как самостоятельный Go-сервис
            и принимает внешние события через собственный HTTP-сервер.
            Оркестратор Google ADK Go остаётся внешним компонентом
            и не является зависимостью сервиса.
        </RATIONALE>
        <TRACES_TO>
            <ACTOR ref="ACTOR-EXTERNAL-SOURCE" />
            <ACTOR ref="ACTOR-GOOGLE-ADK-GO-ORCHESTRATOR" />
            <USE_CASE ref="UC-PERCEPTION-SUBMIT-EXTERNAL-DATA" />
            <USE_CASE ref="UC-PERCEPTION-RETURN-CANONICAL-OBSERVATION" />
        </TRACES_TO>
    </INTEGRATION_INTERFACE>

    <MODULE_IDENTITY id="TECH-MODULE-HARNES-PERCEPTION">
        <PATH>github.com/bogachenko/harnes-perception</PATH>
        <COMPONENT_FORM>GO_SERVICE</COMPONENT_FORM>
        <INTEGRATION_MODE>STANDALONE_HTTP_SERVICE</INTEGRATION_MODE>
        <DEPLOYMENT_UNIT>STANDALONE_PROCESS</DEPLOYMENT_UNIT>
        <DECISION_BASIS>APPROVED_BY_OWNER</DECISION_BASIS>
        <RATIONALE>
            harnes-perception поставляется и запускается как самостоятельный
            Go-сервис с собственным HTTP-сервером.
        </RATIONALE>
        <LANGUAGE ref="TECH-LANGUAGE-GO" />
    </MODULE_IDENTITY>
</TECHNOLOGY>
