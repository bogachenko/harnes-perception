    <INTEGRATION_INTERFACES id="TECH-INTEGRATION-INTERFACES">
        <HTTP_EVENT_INGRESS id="TECH-HTTP-EVENT-INGRESS">
            <MECHANISM>HTTP_INGRESS</MECHANISM>
            <PURPOSE>EXTERNAL_EVENT_INPUT_ONLY</PURPOSE>
            <PROCESS_BOUNDARY>NETWORK_TO_HOST_APPLICATION_PROCESS</PROCESS_BOUNDARY>
            <HTTP_HANDLER_INTERFACE>net/http.Handler</HTTP_HANDLER_INTERFACE>
            <HTTP_HANDLER_LIBRARY>GO_STANDARD_LIBRARY_NET_HTTP</HTTP_HANDLER_LIBRARY>
            <HANDLER_PROVIDER>EXPLICIT_HARNES_PERCEPTION_INSTANCE</HANDLER_PROVIDER>
            <HANDLER_MOUNTING>HOST_APPLICATION</HANDLER_MOUNTING>
            <HTTP_SERVER_OWNERSHIP>HOST_APPLICATION</HTTP_SERVER_OWNERSHIP>
            <ROUTE_SELECTION>HOST_APPLICATION</ROUTE_SELECTION>
            <LISTEN_ADDRESS_AND_PORT_SELECTION>HOST_APPLICATION</LISTEN_ADDRESS_AND_PORT_SELECTION>
            <SERVER_LIFECYCLE>HOST_APPLICATION</SERVER_LIFECYCLE>
            <DEFAULT_SERVE_MUX_REGISTRATION>NONE</DEFAULT_SERVE_MUX_REGISTRATION>
            <PACKAGE_LISTENER_START>NONE</PACKAGE_LISTENER_START>
            <REQUEST_METHOD>POST</REQUEST_METHOD>
            <OTHER_REQUEST_METHODS>REJECT</OTHER_REQUEST_METHODS>
            <REQUEST_CONTENT_TYPE>application/json</REQUEST_CONTENT_TYPE>
            <REQUEST_SERIALIZATION>JSON</REQUEST_SERIALIZATION>
            <REQUEST_DECODER>GO_STANDARD_LIBRARY_ENCODING_JSON</REQUEST_DECODER>
            <REQUEST_BODY_REPRESENTATION ref="TECH-TYPED-GO-INPUT-EVENT" />
            <MULTIPART_FORM_DATA>NONE</MULTIPART_FORM_DATA>
            <FILE_CONTENT_TRANSFER>NONE</FILE_CONTENT_TRANSFER>
            <DECODED_REPRESENTATION ref="TECH-TYPED-GO-INPUT-EVENT" />
            <INSTANCE_BINDING>EXPLICIT_HARNES_PERCEPTION_INSTANCE</INSTANCE_BINDING>
            <EVENT_DISPATCH>COMMAND_TO_CONTROL_EVENT_LOOP</EVENT_DISPATCH>
            <REQUEST_COMPLETION>AFTER_EVENT_LOOP_ACCEPT_OR_REJECT</REQUEST_COMPLETION>
            <INGRESS_DECISION_OWNER ref="TECH-CONTROL-EVENT-LOOP" />
            <ACCEPTANCE_EFFECT>VALIDATED_EVENT_TIMESTAMPED_AND_INSERTED_IN_UNIFIED_QUEUE</ACCEPTANCE_EFFECT>
            <REJECTION_EFFECT>EVENT_NOT_INSERTED_IN_UNIFIED_QUEUE</REJECTION_EFFECT>
            <NORMALIZATION_COMPLETION_WAIT>NONE</NORMALIZATION_COMPLETION_WAIT>
            <READY_STATE_WAIT>NONE</READY_STATE_WAIT>
            <ORCHESTRATOR_OPERATION_ACCESS>NONE</ORCHESTRATOR_OPERATION_ACCESS>
            <DECISION_BASIS>APPROVED_BY_OWNER</DECISION_BASIS>
            <RATIONALE>
                Handler принимает внешнее событие только методом HTTP POST.
                Запросы с другими HTTP-методами отклоняются.
                HTTP используется только для получения JSON-событий от внешних источников.
                Тело запроса с Content-Type application/json содержит source_id, importance,
                data и необязательный artifact как относительный путь либо массив
                относительных путей. Содержимое файлов через HTTP не передаётся.
                Экземпляр предоставляет стандартный net/http.Handler. Использующее приложение
                самостоятельно монтирует handler в собственный http.ServeMux и определяет route,
                адрес, порт и жизненный цикл HTTP-сервера. Пакет не запускает listener
                и не регистрирует handler в глобальном http.DefaultServeMux.
                Обработчик декодирует JSON, передаёт событие управляющему event loop
                того же экземпляра и не изменяет очередь напрямую. Операции управления
                очередью и получение готового наблюдения через Next() через HTTP
                не предоставляются.
                HTTP-запрос завершается только после решения event loop о принятии
                или отклонении события. Принятие включает фиксацию timestamp и помещение
                события в единую очередь. Завершение нормализации и переход в READY
                для ответа на HTTP-запрос не ожидаются.
