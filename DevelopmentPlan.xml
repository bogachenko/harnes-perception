<?xml version="1.0" encoding="UTF-8"?>
<DEVELOPMENT_PLAN id="DP-HARNES-PERCEPTION" status="DRAFT">
    <BASELINES id="DP-BASELINES">
        <REQUIREMENTS_ANALYSIS ref="RA-HARNES-PERCEPTION" required_status="APPROVED_BY_OWNER" />
        <TECHNOLOGY ref="TECH-HARNES-PERCEPTION" required_status="APPROVED_BY_OWNER" />
        <RATIONALE>
            План выполняет утверждённые требования посредством утверждённых технологий.
            Он не изменяет продуктовые требования, архитектурные границы или технологические решения.
        </RATIONALE>
    </BASELINES>

    <EXECUTION_POLICY id="DP-EXECUTION-POLICY">
        <SEQUENCE>CONTRACTS_THEN_MENTAL_SCENARIOS_THEN_CODE_THEN_TESTS_THEN_VERIFICATION</SEQUENCE>
        <PHASE_OVERLAP>NONE</PHASE_OVERLAP>
        <NEXT_PHASE_ENTRY>ONLY_AFTER_PREVIOUS_PHASE_EXIT_GATE</NEXT_PHASE_ENTRY>
        <PRODUCT_REQUIREMENT_CHANGES>RETURN_TO_REQUIREMENTS_ANALYSIS</PRODUCT_REQUIREMENT_CHANGES>
        <TECHNOLOGY_CHANGES>RETURN_TO_TECHNOLOGY</TECHNOLOGY_CHANGES>
        <PUBLIC_CONTRACT_CHANGES_AFTER_APPROVAL>RETURN_TO_CONTRACTS</PUBLIC_CONTRACT_CHANGES_AFTER_APPROVAL>
        <ESTIMATES_AND_NUMERIC_SLA>NONE</ESTIMATES_AND_NUMERIC_SLA>
        <TRACES_TO>
            <CONSTRAINT ref="CONSTRAINT-PERCEPTION-NO-NUMERIC-SLA" />
        </TRACES_TO>
    </EXECUTION_POLICY>

    <SCOPE_GUARDS id="DP-SCOPE-GUARDS">
        <EXTERNAL_BROKER>OUT_OF_SCOPE</EXTERNAL_BROKER>
        <DATABASE_OR_PERSISTENCE>OUT_OF_SCOPE</DATABASE_OR_PERSISTENCE>
        <STANDALONE_PROCESS>OUT_OF_SCOPE</STANDALONE_PROCESS>
        <PACKAGE_OWNED_HTTP_SERVER>OUT_OF_SCOPE</PACKAGE_OWNED_HTTP_SERVER>
        <DIRECT_GOOGLE_ADK_GO_DEPENDENCY>OUT_OF_SCOPE</DIRECT_GOOGLE_ADK_GO_DEPENDENCY>
        <AUTHENTICATION_AND_AUTHORIZATION>OUT_OF_SCOPE</AUTHENTICATION_AND_AUTHORIZATION>
        <MULTIPART_OR_FILE_UPLOAD>OUT_OF_SCOPE</MULTIPART_OR_FILE_UPLOAD>
        <SEMANTIC_ENRICHMENT>OUT_OF_SCOPE</SEMANTIC_ENRICHMENT>
        <IMPORTANCE_ASSIGNMENT>EXTERNAL_SOURCE_RESPONSIBILITY</IMPORTANCE_ASSIGNMENT>
        <NOISE_CLASSIFICATION>EXTERNAL_SOURCE_RESPONSIBILITY</NOISE_CLASSIFICATION>
        <TRACES_TO>
            <REQUIREMENT ref="REQ-PERCEPTION-IMPORTANCE-SOURCE" />
